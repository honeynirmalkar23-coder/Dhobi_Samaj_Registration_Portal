# Authentication mode:
# supabase | local-dev
VITE_ADMIN_AUTH_MODE=local-dev

# Supabase is not being used for local administrator login
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Development-only administrator credentials
DEV_ADMIN_EMAIL=admin@test.com

DEV_ADMIN_PASSWORD_HASH=PASTE_GENERATED_BCRYPT_HASH_HERE

# Generate a new random secret for each local environment
DEV_ADMIN_SESSION_SECRET=PASTE_RANDOM_SESSION_SECRET_HERE

# 480 minutes = 8 hours
DEV_ADMIN_SESSION_TTL_MINUTES=480

# Allow login only from this Mac
DEV_ADMIN_ALLOW_LAN=false
VITE_DATA_BACKEND_MODE=local-dev
DEV_PORTAL_SIGNING_SECRET=PASTE_RANDOM_PORTAL_SIGNING_SECRET_HERE
DEV_PORTAL_DATA_DIRECTORY=.local-data
